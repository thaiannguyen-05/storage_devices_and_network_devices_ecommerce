# ============================================================
# Java / Ant build outputs
# ============================================================
/build/
/dist/
/out/
/target/
*.class
*.war
*.ear
*.jar

# Keep dependency jars stored in source control (lib folder)
!lib/**/*.jar

# ============================================================
# NetBeans
# ============================================================
/nbproject/private/
/nbbuild/
/nbdist/
/.nb-gradle/
nbproject/Makefile-*.mk
nbproject/Package-*.bash

# ============================================================
# IntelliJ IDEA
# ============================================================
/.idea/
*.iml
*.iws
*.ipr
out/

# ============================================================
# Eclipse
# ============================================================
.classpath
.project
.settings/

# ============================================================
# VS Code
# ============================================================
/.vscode/*
!/.vscode/extensions.json
!/.vscode/settings.json
!/.vscode/tasks.json
!/.vscode/launch.json

# ============================================================
# Logs & runtime temp files
# ============================================================
*.log
logs/
tmp/
temp/
*.tmp
*.cache

# ============================================================
# OS noise
# ============================================================
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db
$RECYCLE.BIN/

# ============================================================
# Environment and secrets
# ============================================================
/.env
/.env.*
!/.env.example
*.key
*.pem
*.p12
*.jks
*.keystore

# ============================================================
# Archive files
# ============================================================
*.zip
*.tar
*.gz
*.7z
*.rar

# ============================================================
# Web / Frontend assets (if applicable)
# ============================================================
node_modules/
npm-debug.log*
yarn-error.log*
